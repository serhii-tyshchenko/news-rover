{
  "name": "news-rover-integration-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright integration tests for News Rover",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:ui": "playwright test --ui",
