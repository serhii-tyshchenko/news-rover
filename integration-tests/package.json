    "report": "playwright show-report",
    "install:browsers": "playwright install"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.8.3"
  }
}
